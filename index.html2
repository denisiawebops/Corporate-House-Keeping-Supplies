            {id:'GB02',name:'Garbage Bag Color',category:'Garbage Bags & Door Mats',tier:TIER.ECONOMY,image:IMG.bag,desc:'Color coded.'},
            {id:'GB03',name:'Garbage Bag Biodegradable',category:'Garbage Bags & Door Mats',tier:TIER.PREMIUM,image:IMG.bag,desc:'Compostable.'},
            {id:'GB04',name:'Door Mat Cotton & Plastic',category:'Garbage Bags & Door Mats',tier:TIER.INTERMEDIATE,image:IMG.bag,desc:'Entrance mats.'},
            {id:'GB05',name:'Soft Broom Hard Broom',category:'Garbage Bags & Door Mats',tier:TIER.ECONOMY,image:IMG.floor,desc:'Indoor/outdoor brooms.'},
            {id:'GB06',name:'Hotel Guest Amenities Kit',category:'Garbage Bags & Door Mats',tier:TIER.PREMIUM,image:IMG.amenity,desc:'Soap, shampoo, etc.'},
            {id:'GB07',name:'Office Stationery Office Solution',category:'Garbage Bags & Door Mats',tier:TIER.INTERMEDIATE,image:IMG.amenity,desc:'Stationery supplies.'},
            {id:'GB08',name:'Printer Cartridge Refilling & New',category:'Garbage Bags & Door Mats',tier:TIER.INTERMEDIATE,image:IMG.amenity,desc:'Toner refill.'},

            // DUSTER & CLOTH
            {id:'DC01',name:'Yellow Duster Small/Medium/Big',category:'Duster & Cloth',tier:TIER.ECONOMY,image:IMG.duster,desc:'Yellow dusting cloth.'},
            {id:'DC02',name:'Glass Duster',category:'Duster & Cloth',tier:TIER.ECONOMY,image:IMG.duster,desc:'For glass.'},
            {id:'DC03',name:'Floor Duster Small/Medium/Big',category:'Duster & Cloth',tier:TIER.ECONOMY,image:IMG.duster,desc:'Floor cloth.'},
            {id:'DC04',name:'Check Duster Small/Big',category:'Duster & Cloth',tier:TIER.ECONOMY,image:IMG.duster,desc:'Checked pattern.'},

            // SCRAPER
            {id:'SC01',name:'Mini Scraper',category:'Scraper',tier:TIER.ECONOMY,image:IMG.scraper,desc:'Handheld.'},
            {id:'SC02',name:'Floor Scraper Grey',category:'Scraper',tier:TIER.INTERMEDIATE,image:IMG.scraper,desc:'Heavy duty.'},
            {id:'SC03',name:'Stainless Steel Scraper',category:'Scraper',tier:TIER.PREMIUM,image:IMG.scraper,desc:'SS blade.'},
            {id:'SC04',name:'Scraper Blade',category:'Scraper',tier:TIER.ECONOMY,image:IMG.scraper,desc:'Replacement blade.'}
        ];

        MOCK_PRODUCTS.forEach(p => p.gallery = generateWebpGallery(p.image));

        const CATEGORIES = ['All Segments', ...new Set(MOCK_PRODUCTS.map(p => p.category))].sort((a,b)=>a==='All Segments'?-1:b==='All Segments'?1:a.localeCompare(b));

        // ==========================================
        // 2. STATE
        // ==========================================
        const state = {
            currentView: 'catalog',
            cart: JSON.parse(localStorage.getItem('echopills_cart')) || [],
            searchCatalog: '', activeCatCatalog: 'All Segments',
            searchCorp: '', activeCatCorp: 'All Segments'
        };

        // ==========================================
        // 3. NAVIGATION & UI
        // ==========================================
        function navigate(view){
            state.currentView = view;
            ['catalog','corporate-gifting','contact','rfq','success'].forEach(v=>document.getElementById(`view-${v}`).classList.add('view-hidden'));
            if(view==='catalog') document.getElementById('view-catalog').classList.remove('view-hidden');
            else if(view==='corporate-gifting') document.getElementById('view-corporate-gifting').classList.remove('view-hidden');
            else document.getElementById(`view-${view}`).classList.remove('view-hidden');
            closeCart();
            window.scrollTo(0,0);
            if(view==='catalog') { renderProducts('catalog'); renderCategories('catalog'); }
            else if(view==='corporate-gifting') { renderProducts('corporate-gifting'); renderCategories('corporate-gifting'); }
            if(view==='rfq') renderRfqSummary();
        }

        function makeRenderFunctions(prefix){
            return {
                renderProducts: ()=>{
                    const container = document.getElementById(`productsContainer${prefix==='catalog'?'Catalog':'CorpGift'}`);
                    const empty = document.getElementById(`emptyState${prefix==='catalog'?'Catalog':'CorpGift'}`);
                    const searchQ = state[prefix==='catalog'?'searchCatalog':'searchCorp'];
                    const activeCat = state[prefix==='catalog'?'activeCatCatalog':'activeCatCorp'];
                    const filtered = MOCK_PRODUCTS.filter(p=>{
                        const matchCat = activeCat==='All Segments' || p.category===activeCat;
                        const matchSearch = p.name.toLowerCase().includes(searchQ) || p.category.toLowerCase().includes(searchQ);
                        return matchCat && matchSearch;
                    });
                    document.getElementById(`productCount${prefix==='catalog'?'Catalog':'CorpGift'}`).innerText = `${filtered.length} items`;
                    if(filtered.length===0){container.innerHTML='';empty.classList.remove('hidden');return;}
                    empty.classList.add('hidden');
                    const grouped = {};
                    filtered.forEach(p=>{if(!grouped[p.category]) grouped[p.category]=[]; grouped[p.category].push(p);});
                    let html='';
                    for(const [cat,prods] of Object.entries(grouped)){
                        const carId = `carousel-${cat.replace(/[^a-zA-Z0-9]/g,'-')}-${prefix}`;
                        html+=`<div class="bg-white p-6 rounded-xl border shadow-sm"><div class="flex justify-between mb-4"><div><h3 class="text-xl font-bold">${cat}</h3><span class="ml-3 px-2 py-0.5 bg-slate-100 text-xs rounded-full">${prods.length}</span></div><div class="flex gap-2"><button onclick="scrollCarousel('${carId}',-1)" class="p-2 rounded-full bg-slate-50 border hover:text-brand-600"><i class="ph ph-caret-left"></i></button><button onclick="scrollCarousel('${carId}',1)" class="p-2 rounded-full bg-slate-50 border hover:text-brand-600"><i class="ph ph-caret-right"></i></button></div></div><div id="${carId}" class="flex overflow-x-auto gap-5 pb-4 snap-x snap-mandatory no-scrollbar">${prods.map(p=>`
                            <div class="w-[260px] flex-shrink-0 snap-start bg-white rounded-lg border shadow-sm hover:shadow-lg transition group flex flex-col">
                                <div onclick="openPopup('${p.id}')" class="relative h-48 bg-slate-100 overflow-hidden cursor-pointer"><img src="${p.image}" alt="${p.name}" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" loading="lazy"><div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 flex items-center justify-center"><i class="ph ph-arrows-out text-white opacity-0 group-hover:opacity-100 text-3xl transition"></i></div></div>
                                <div class="p-5 flex flex-col flex-1"><div class="mb-1"><span class="text-[9px] font-bold uppercase px-2 py-0.5 rounded ${p.tier==='Premium'?'bg-purple-50 text-purple-700':p.tier==='Intermediate'?'bg-amber-50 text-amber-700':'bg-green-50 text-green-700'}">${p.tier}</span></div><h4 onclick="openPopup('${p.id}')" class="text-sm font-bold mb-2 cursor-pointer hover:text-brand-600">${p.name}</h4><p class="text-xs text-slate-500 mb-5 line-clamp-2">${p.desc}</p><button onclick="addToCart('${p.id}');event.stopPropagation()" class="w-full py-2.5 px-4 border border-brand-200 text-sm font-semibold rounded-md text-brand-700 bg-brand-50 hover:bg-brand-600 hover:text-white transition"><i class="ph ph-plus-circle mr-1.5"></i>Add to Quote</button></div>
                            </div>`).join('')}</div></div>`;
                    }
                    container.innerHTML = html;
                },
                setCategory: (cat)=>{
                    if(prefix==='catalog') state.activeCatCatalog = cat;
                    else state.activeCatCorp = cat;
                    document.getElementById(`currentCategoryTitle${prefix==='catalog'?'Catalog':'CorpGift'}`).innerText = cat;
                    makeRenderFunctions(prefix).renderCategories();
                    makeRenderFunctions(prefix).renderProducts();
                },
                renderCategories: ()=>{
                    const list = document.getElementById(`categoryList${prefix==='catalog'?'Catalog':'CorpGift'}`);
                    const activeCat = state[prefix==='catalog'?'activeCatCatalog':'activeCatCorp'];
                    list.innerHTML = CATEGORIES.map(cat=>`<li><button onclick="window.setCategory${prefix==='catalog'?'Catalog':'CorpGift'}('${cat.replace(/'/g,"\\'")}')" class="w-full text-left px-3 py-2.5 rounded-md text-sm transition ${activeCat===cat?'bg-brand-50 text-brand-800 font-bold border':'text-slate-600 hover:bg-slate-50'}">${cat}</button></li>`).join('');
                }
            };
        }
        const catalogRenderer = makeRenderFunctions('catalog');
        const corpGiftRenderer = makeRenderFunctions('corporate-gifting');
        window.setCategoryCatalog = catalogRenderer.setCategory;
        window.setCategoryCorpGift = corpGiftRenderer.setCategory;

        function renderProducts(view){ if(view==='catalog') catalogRenderer.renderProducts(); else corpGiftRenderer.renderProducts(); }
        function renderCategories(view){ if(view==='catalog') catalogRenderer.renderCategories(); else corpGiftRenderer.renderCategories(); }
        function resetFilters(view){ if(view==='catalog'){state.searchCatalog='';document.getElementById('searchInputCatalog').value='';catalogRenderer.setCategory('All Segments');} else {state.searchCorp='';document.getElementById('searchInputCorpGift').value='';corpGiftRenderer.setCategory('All Segments');} }

        document.getElementById('searchInputCatalog').addEventListener('input',e=>{state.searchCatalog=e.target.value.toLowerCase();renderProducts('catalog')});
        document.getElementById('searchInputCorpGift').addEventListener('input',e=>{state.searchCorp=e.target.value.toLowerCase();renderProducts('corporate-gifting')});

        function scrollCarousel(id,dir){const el=document.getElementById(id);if(el)el.scrollBy({left:260*2.5*dir,behavior:'smooth'});}

        // ==========================================
        // POPUP & CART (same logic)
        // ==========================================
        function openPopup(pid){
            const p = MOCK_PRODUCTS.find(x=>x.id===pid); if(!p)return;
            document.getElementById('popupTitle').innerText=p.name; document.getElementById('popupDesc').innerText=p.desc;
            document.getElementById('popupCategory').innerText=p.category; document.getElementById('popupTier').innerText=p.tier;
            document.getElementById('popupCarouselImages').innerHTML = p.gallery.map((img,i)=>`<div class="carousel-item flex-shrink-0 w-[60%] h-56 snap-center rounded-2xl overflow-hidden shadow-lg border-4 border-white"><img src="${img}" alt="pic" class="w-full h-full object-cover"></div>`).join('');
            document.getElementById('popupCarouselImages').scrollLeft=0;
            document.getElementById('popupAddBtn').onclick=()=>{addToCart(p.id);closePopup();};
            const pop=document.getElementById('productPopup'); pop.classList.remove('hidden'); pop.classList.add('flex');
            requestAnimationFrame(()=>{document.getElementById('popupBackdrop').classList.remove('opacity-0');document.getElementById('popupContent').classList.remove('scale-95','opacity-0');document.getElementById('popupContent').classList.add('scale-100','opacity-100');updateCarouselScale();});
        }
        function closePopup(){document.getElementById('popupBackdrop').classList.add('opacity-0');document.getElementById('popupContent').classList.add('scale-95','opacity-0');setTimeout(()=>{document.getElementById('productPopup').classList.add('hidden');},300);}
        function updateCarouselScale(){/* same as before */}

        function addToCart(pid){const p=MOCK_PRODUCTS.find(x=>x.id===pid);const exist=state.cart.find(i=>i.id===pid);if(exist)exist.qty++; else state.cart.push({...p,qty:1});saveCart();}
        function updateQty(pid,d){const it=state.cart.find(i=>i.id===pid);if(it){it.qty+=d;if(it.qty<=0)state.cart=state.cart.filter(i=>i.id!==pid);}saveCart();}
        function removeFromCart(pid){state.cart=state.cart.filter(i=>i.id!==pid);saveCart();}
        function clearCart(){state.cart=[];saveCart();}
        function saveCart(){localStorage.setItem('echopills_cart',JSON.stringify(state.cart));updateCartUI();}
        function updateCartUI(){ /* same as earlier, updates cart drawer and badge */ }
        let drawerOpen=false;
        function toggleCart(){drawerOpen=!drawerOpen; /* toggle classes */ }
        function closeCart(){if(drawerOpen)toggleCart();}
        function proceedToRfq(){if(state.cart.length===0){alert('Add items first');return;} navigate('rfq');}
        function renderRfqSummary(){ /* fill summary */ }
        function submitRFQ(e){e.preventDefault(); /* simulate submission, clear cart, navigate success */ }
        function submitContactForm(e){e.preventDefault(); alert('Thank you! We will get back to you soon.'); e.target.reset();}

        // init
        window.addEventListener('DOMContentLoaded',()=>{
            navigate('catalog');
            renderCategories('catalog');
            renderProducts('catalog');
        });
    </script>
</body>
</html>
