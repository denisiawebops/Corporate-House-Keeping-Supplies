<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col">

    <!-- ==================== HEADER (CONSISTENT ACROSS ALL PAGES) ==================== -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center cursor-pointer" onclick="navigate('catalog')">
                    <i class="ph-fill ph-buildings text-brand-800 text-3xl"></i>
                    <div class="ml-2 flex flex-col">
                        <span class="text-xl font-bold tracking-tight text-slate-900 leading-none">ECHOPILLS</span>
                        <span class="text-[10px] font-semibold tracking-wider text-slate-500 uppercase leading-none mt-1">Hospitality & Hygiene</span>
                    </div>
                </div>
                <nav class="hidden md:flex items-center space-x-6 text-sm font-medium text-slate-600">
                    <a href="javascript:void(0)" onclick="navigate('catalog')" class="hover:text-brand-700 transition" id="nav-catalog">Catalog</a>
                    <a href="javascript:void(0)" onclick="navigate('corporate-gifting')" class="hover:text-brand-700 transition" id="nav-corp-gifting">Corporate Gifting</a>
                    <a href="javascript:void(0)" onclick="navigate('contact')" class="hover:text-brand-700 transition" id="nav-contact">Contact Us</a>
                </nav>
                <div class="flex items-center space-x-4">
                    <button onclick="toggleCart()" class="text-slate-500 hover:text-brand-800 p-2 relative transition-colors rounded-full hover:bg-slate-100" aria-label="Cart">
                        <i class="ph ph-shopping-cart text-2xl"></i>
                        <span id="cart-badge" class="hidden absolute top-0 right-0 items-center justify-center px-2 py-1 text-xs font-bold text-white bg-red-500 rounded-full transform translate-x-1/4 -translate-y-1/4">0</span>
                    </button>
                    <button onclick="proceedToRfq()" class="hidden sm:inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-md text-white bg-brand-800 hover:bg-brand-900 transition-colors shadow-sm">Request Quote</button>
                </div>
            </div>
        </div>
    </header>

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="flex-1 flex flex-col">

        <!-- VIEW: CATALOG (HOME) -->
        <div id="view-catalog" class="flex-1 flex flex-col view-hidden w-full">
            <div class="bg-brand-900 text-white py-12 px-4 sm:px-6 lg:px-8 text-center relative overflow-hidden">
                <div class="absolute inset-0 opacity-10 bg-[url('https://images.unsplash.com/photo-1584813470613-5b1c1cad3d69?auto=format&fit=crop&q=80&w=1600&fm=webp')] bg-cover bg-center mix-blend-overlay"></div>
                <div class="relative max-w-3xl mx-auto z-10">
                    <p class="text-brand-200 text-xs font-bold tracking-widest uppercase mb-2">ISO 9001:2015 Certified</p>
                    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Optimizing Your Commercial Procurement</h1>
                    <p class="text-lg text-brand-100 mb-8 max-w-2xl mx-auto font-light">Explore our full range of housekeeping, hygiene, chemical, and dispensing solutions.</p>
                    <div class="max-w-xl mx-auto relative text-slate-900 shadow-lg rounded-full">
                        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none"><i class="ph ph-magnifying-glass text-slate-400 text-lg"></i></div>
                        <input type="text" id="searchInputCatalog" class="block w-full rounded-full border-0 py-3.5 pl-12 pr-4 shadow-sm ring-1 ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-brand-600 sm:text-sm" placeholder="Search by product name, category, or tier...">
                    </div>
                </div>
            </div>
            <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 mt-8 w-full flex-1">
                <div class="flex flex-col md:flex-row md:space-x-8">
                    <div class="w-full md:w-64 flex-shrink-0 mb-6 md:mb-0">
                        <div class="bg-white p-5 rounded-lg shadow-sm border border-slate-200 md:sticky md:top-24">
                            <h3 class="text-lg font-medium text-slate-900 mb-4 flex items-center"><i class="ph ph-funnel text-slate-500 mr-2"></i> Segments</h3>
                            <ul id="categoryListCatalog" class="space-y-1"></ul>
                        </div>
                    </div>
                    <div class="flex-1 overflow-hidden">
                        <div class="mb-6 flex items-center justify-between"><h2 id="currentCategoryTitleCatalog" class="text-2xl font-bold text-slate-800 tracking-tight">All Segments</h2><span id="productCountCatalog" class="text-sm font-medium text-slate-500 bg-slate-200 px-3 py-1 rounded-full">0 items</span></div>
                        <div id="emptyStateCatalog" class="hidden text-center py-20 bg-white rounded-lg border border-dashed"><i class="ph ph-package text-5xl text-slate-300 mb-3"></i><h3 class="text-sm font-semibold text-slate-900">No products found</h3><p class="mt-1 text-sm text-slate-500">Adjust your search or category.</p><button onclick="resetFilters('catalog')" class="mt-4 px-4 py-2 border rounded-md text-sm">Clear Filters</button></div>
                        <div id="productsContainerCatalog" class="flex flex-col space-y-10"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- VIEW: CORPORATE GIFTING (SAME PRODUCTS, DIFFERENT HERO) -->
        <div id="view-corporate-gifting" class="flex-1 flex flex-col view-hidden w-full">
            <div class="bg-gradient-to-r from-purple-800 to-indigo-900 text-white py-12 px-4 sm:px-6 lg:px-8 text-center relative overflow-hidden">
                <div class="absolute inset-0 opacity-10 bg-[url('https://images.unsplash.com/photo-1513201099705-a9746e1e201f?auto=format&fit=crop&q=80&w=1600&fm=webp')] bg-cover bg-center mix-blend-overlay"></div>
                <div class="relative max-w-3xl mx-auto z-10">
                    <p class="text-purple-200 text-xs font-bold tracking-widest uppercase mb-2">Corporate Gifting & Bulk Orders</p>
                    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Curated Corporate Gifts & Supplies</h1>
                    <p class="text-lg text-purple-100 mb-8 max-w-2xl mx-auto font-light">Amenities kits, stationery, premium cleaning products, and more — perfect for corporate gifting.</p>
                    <div class="max-w-xl mx-auto relative text-slate-900 shadow-lg rounded-full">
                        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none"><i class="ph ph-magnifying-glass text-slate-400 text-lg"></i></div>
                        <input type="text" id="searchInputCorpGift" class="block w-full rounded-full border-0 py-3.5 pl-12 pr-4 shadow-sm ring-1 ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-purple-600 sm:text-sm" placeholder="Search gifts, amenities, stationery...">
                    </div>
                </div>
            </div>
            <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 mt-8 w-full flex-1">
                <div class="flex flex-col md:flex-row md:space-x-8">
                    <div class="w-full md:w-64 flex-shrink-0 mb-6 md:mb-0">
                        <div class="bg-white p-5 rounded-lg shadow-sm border border-slate-200 md:sticky md:top-24">
                            <h3 class="text-lg font-medium text-slate-900 mb-4 flex items-center"><i class="ph ph-gift text-purple-500 mr-2"></i> Gift Categories</h3>
                            <ul id="categoryListCorpGift" class="space-y-1"></ul>
                        </div>
                    </div>
                    <div class="flex-1 overflow-hidden">
                        <div class="mb-6 flex items-center justify-between"><h2 id="currentCategoryTitleCorpGift" class="text-2xl font-bold text-slate-800 tracking-tight">All Gifts</h2><span id="productCountCorpGift" class="text-sm font-medium text-slate-500 bg-slate-200 px-3 py-1 rounded-full">0 items</span></div>
                        <div id="emptyStateCorpGift" class="hidden text-center py-20 bg-white rounded-lg border border-dashed"><i class="ph ph-package text-5xl text-slate-300 mb-3"></i><h3 class="text-sm font-semibold text-slate-900">No gifts found</h3><button onclick="resetFilters('corporate-gifting')" class="mt-4 px-4 py-2 border rounded-md text-sm">Clear Filters</button></div>
                        <div id="productsContainerCorpGift" class="flex flex-col space-y-10"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- VIEW: CONTACT US -->
        <div id="view-contact" class="flex-1 flex flex-col view-hidden w-full fade-in">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
                <h1 class="text-3xl font-extrabold text-slate-900 mb-8">Contact Us</h1>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                    <div class="bg-white rounded-xl shadow-sm border p-8">
                        <h2 class="text-xl font-bold mb-6">Send us a message</h2>
                        <form id="contactForm" onsubmit="submitContactForm(event)" class="space-y-4">
                            <input type="text" placeholder="Your Name" required class="w-full rounded-md border border-slate-300 py-2 px-3 shadow-sm focus:ring-brand-500">
                            <input type="email" placeholder="Email Address" required class="w-full rounded-md border border-slate-300 py-2 px-3 shadow-sm">
                            <input type="text" placeholder="Subject" class="w-full rounded-md border border-slate-300 py-2 px-3 shadow-sm">
                            <textarea rows="4" placeholder="Your Message" required class="w-full rounded-md border border-slate-300 py-2 px-3 shadow-sm"></textarea>
                            <button type="submit" class="w-full bg-brand-800 text-white py-3 rounded-md font-bold hover:bg-brand-900 transition">Submit Message</button>
                        </form>
                    </div>
                    <div class="bg-white rounded-xl shadow-sm border p-8">
                        <h2 class="text-xl font-bold mb-6">ECHOPILLS Headquarters</h2>
                        <div class="space-y-4 text-slate-700">
                            <div class="flex items-start gap-3"><i class="ph ph-map-pin text-brand-600 text-2xl"></i><p>Door No L4-07, Spendid Plaza, 26, Wheeler Rd, Cox Town, Bengaluru, Karnataka 560005</p></div>
                            <div class="flex items-center gap-3"><i class="ph ph-phone text-brand-600 text-2xl"></i><a href="tel:+919480114897" class="hover:text-brand-700">+91 9480114897</a> / <a href="tel:+918762464897" class="hover:text-brand-700">+91 8762464897</a></div>
                            <div class="flex items-center gap-3"><i class="ph ph-envelope text-brand-600 text-2xl"></i><a href="mailto:info@echopills.in" class="hover:text-brand-700">info@echopills.in</a></div>
                            <div class="flex items-center gap-3"><i class="ph ph-globe text-brand-600 text-2xl"></i><a href="https://www.echopills.in" target="_blank" class="hover:text-brand-700">www.echopills.in</a></div>
                        </div>
                        <div class="mt-8">
                            <iframe title="ECHOPILLS location" class="w-full h-48 rounded-lg border" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3887.507689123456!2d77.5946!3d12.9716!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTLCsDU4JzE3LjgiTiA3N8KwMzUnNDAuNiJF!5e0!3m2!1sen!2sin!4v1610000000000" allowfullscreen="" loading="lazy"></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- VIEW: RFQ FORM -->
        <div id="view-rfq" class="flex-1 bg-slate-50 py-10 w-full view-hidden fade-in">
            <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
                <button onclick="navigate('catalog')" class="flex items-center text-sm text-slate-500 hover:text-slate-900 mb-6"><i class="ph ph-caret-left mr-1"></i> Back to Catalog</button>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <div class="px-6 py-5 border-b bg-brand-900 text-white"><h2 class="text-xl font-semibold flex items-center"><i class="ph ph-file-text text-brand-300 mr-2"></i>Request for Quotation</h2><p class="text-sm text-brand-100">We'll email you a formal quotation with pricing.</p></div>
                    <div class="p-6 md:p-8 flex flex-col md:flex-row gap-8">
                        <form id="rfqForm" onsubmit="submitRFQ(event)" class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-6">
                            <input type="text" id="rfqCompany" placeholder="Company Name *" required class="rounded-md border py-2 px-3">
                            <input type="text" id="rfqName" placeholder="Contact Person *" required class="rounded-md border py-2 px-3">
                            <input type="email" id="rfqEmail" placeholder="Email *" required class="rounded-md border py-2 px-3">
                            <input type="tel" id="rfqPhone" placeholder="Phone *" required class="rounded-md border py-2 px-3">
                            <input type="text" id="rfqLocation" placeholder="Delivery Location *" required class="rounded-md border py-2 px-3 md:col-span-2">
                            <textarea id="rfqNotes" rows="3" placeholder="Additional notes..." class="rounded-md border py-2 px-3 md:col-span-2"></textarea>
                            <button type="submit" id="submitBtn" class="md:col-span-2 bg-brand-800 text-white py-3 rounded-md font-bold hover:bg-brand-900">Submit Quote Request</button>
                        </form>
                        <div class="w-full md:w-80 bg-slate-50 p-5 border rounded-lg h-fit">
                            <h3 class="font-semibold border-b pb-2">Summary (<span id="rfqSummaryCount">0</span>)</h3>
                            <ul id="rfqSummaryList" class="space-y-2 mt-2 text-sm max-h-96 overflow-y-auto"></ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- VIEW: SUCCESS -->
        <div id="view-success" class="flex-1 flex items-center justify-center py-20 px-4 w-full view-hidden fade-in">
            <div class="max-w-md bg-white rounded-xl shadow-sm border p-8 text-center">
                <i class="ph-fill ph-check-circle text-6xl text-green-500 mb-4"></i>
                <h2 class="text-2xl font-bold mb-2">Request Submitted!</h2>
                <p class="text-slate-600 mb-8">Thank you. We'll contact you shortly with the best pricing.</p>
                <button onclick="navigate('catalog')" class="bg-brand-800 text-white py-2.5 px-6 rounded-md font-medium hover:bg-brand-900">Return to Catalog</button>
            </div>
        </div>
    </main>

    <!-- ==================== FOOTER (CONSISTENT) ==================== -->
    <footer class="bg-slate-900 text-slate-400 py-10 mt-auto border-t border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
                <span class="text-lg font-bold text-white flex items-center"><i class="ph-fill ph-buildings text-brand-500 mr-2"></i>ECHOPILLS</span>
                <p class="text-sm mt-2">AN ISO 9001:2015 CERTIFIED COMPANY</p>
                <p class="text-xs mt-2">Your advanced multifaceted trading partner for housekeeping, hygiene, and corporate gifting.</p>
            </div>
            <div>
                <h4 class="text-white font-semibold mb-3">Quick Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="javascript:void(0)" onclick="navigate('catalog')" class="hover:text-white transition">Product Catalog</a></li>
                    <li><a href="javascript:void(0)" onclick="navigate('corporate-gifting')" class="hover:text-white transition">Corporate Gifting</a></li>
                    <li><a href="javascript:void(0)" onclick="navigate('contact')" class="hover:text-white transition">Contact Us</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-white font-semibold mb-3">Contact Info</h4>
                <p class="text-sm">Door No L4-07, Spendid Plaza, 26, Wheeler Rd, Cox Town, Bengaluru, Karnataka 560005</p>
                <p class="text-sm mt-2">+91 9480114897 / +91 8762464897</p>
                <p class="text-sm">www.echopills.in</p>
            </div>
        </div>
        <div class="text-center text-xs text-slate-500 mt-8 border-t border-slate-800 pt-6">© 2025 ECHOPILLS. All rights reserved. Proudly supporting Swachh Bharat Abhiyan.</div>
    </footer>

    <!-- CART DRAWER (SAME) -->
    <div id="cartDrawerWrapper" class="fixed inset-0 z-50 pointer-events-none opacity-0 transition-opacity duration-300">
        <div class="absolute inset-0 bg-slate-900/50" onclick="toggleCart()"></div>
        <div id="cartDrawer" class="absolute right-0 h-full bg-white shadow-xl w-screen md:max-w-md flex flex-col translate-x-full transition-transform duration-300">
            <div class="flex justify-between items-center p-4 border-b"><h2 class="text-lg font-medium"><i class="ph ph-shopping-cart mr-2 text-brand-600"></i>Request Cart</h2><button onclick="toggleCart()" class="p-1 rounded-full bg-slate-100"><i class="ph ph-x text-xl"></i></button></div>
            <div class="flex-1 overflow-y-auto p-4 bg-slate-50"><div id="cartEmptyState" class="hidden text-center py-12"><i class="ph ph-basket text-5xl text-slate-300"></i><p class="mt-2">Empty</p></div><ul id="cartItemsList" class="space-y-4"></ul></div>
            <div id="cartFooter" class="p-4 border-t bg-white"><div class="flex justify-between text-sm mb-2"><span>Total Items</span><span id="cartTotalItemsCount" class="font-bold text-lg">0</span></div><div class="flex gap-2"><button onclick="clearCart()" class="flex-1 border py-2 rounded-md text-sm">Clear</button><button onclick="proceedToRfq()" class="flex-1 bg-brand-800 text-white py-2 rounded-md text-sm font-bold">Create Quote</button></div></div>
        </div>
    </div>

    <!-- PRODUCT POPUP (SAME) -->
    <div id="productPopup" class="fixed inset-0 z-[60] hidden items-center justify-center pointer-events-none">
        <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm opacity-0 transition-opacity pointer-events-auto" id="popupBackdrop" onclick="closePopup()"></div>
        <div id="popupContent" class="bg-white rounded-[1.5rem] shadow-2xl w-[95%] max-w-[640px] relative z-10 transform scale-95 opacity-0 transition-all duration-300 pointer-events-auto flex flex-col border">
            <button onclick="closePopup()" class="absolute top-4 right-4 z-30 p-2 bg-white/90 rounded-full shadow-md"><i class="ph-bold ph-x text-lg"></i></button>
            <div class="relative bg-slate-100 pt-8 pb-6 border-b overflow-hidden">
                <div class="absolute top-3 left-1/2 -translate-x-1/2 z-20 text-[10px] font-bold tracking-widest text-slate-400 uppercase flex items-center bg-white/60 px-3 py-1 rounded-full backdrop-blur-sm"><i class="ph ph-arrows-left-right mr-1.5 text-sm"></i>Swipe</div>
                <div id="popupCarouselImages" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar w-full px-[20%] gap-4 items-center h-[280px]"></div>
            </div>
